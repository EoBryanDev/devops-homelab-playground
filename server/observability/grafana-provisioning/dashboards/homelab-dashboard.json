{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "title": "Homelab — Full Observability",
  "uid": "homelab-full-obs",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "tags": ["homelab", "nodejs", "otel"],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🌐 HTTP — Throughput & Errors",
      "type": "row"
    },
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] } }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "sum(rate(http_server_duration_count[1m]))", "refId": "A" }]
    },
    {
      "id": 2,
      "title": "Error Rate (5xx)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "sum(rate(http_server_duration_count{http_status_code=~\"5..\"}[1m])) / sum(rate(http_server_duration_count[1m]))", "refId": "A" }]
    },
    {
      "id": 3,
      "title": "P99 Latency",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 500 }] } }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_duration_bucket[1m]))) * 1000", "refId": "A" }]
    },
    {
      "id": 4,
      "title": "Active Requests",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "sum(http_server_active_requests)", "refId": "A" }]
    },
    {
      "id": 5,
      "title": "HTTP Throughput by Route & Status",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum by (http_route, http_status_code) (rate(http_server_duration_count[1m]))",
        "legendFormat": "{{http_route}} [{{http_status_code}}]",
        "refId": "A"
      }]
    },
    {
      "id": 6,
      "title": "HTTP Latency Percentiles (P50 / P95 / P99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_duration_bucket[1m]))) * 1000", "legendFormat": "P50", "refId": "A" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_duration_bucket[1m]))) * 1000", "legendFormat": "P95", "refId": "B" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_duration_bucket[1m]))) * 1000", "legendFormat": "P99", "refId": "C" }
      ]
    },
    {
      "id": 7,
      "title": "HTTP Errors Over Time (4xx / 5xx)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 13 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 20 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": "Prometheus", "expr": "sum(rate(http_server_duration_count{http_status_code=~\"5..\"}[1m]))", "legendFormat": "5xx", "refId": "A" },
        { "datasource": "Prometheus", "expr": "sum(rate(http_server_duration_count{http_status_code=~\"4..\"}[1m]))", "legendFormat": "4xx", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 101,
      "title": "🖥️ System — Node & Container Resources",
      "type": "row"
    },
    {
      "id": 10,
      "title": "CPU Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": "Prometheus", "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m]))", "legendFormat": "CPU Total", "refId": "A" }
      ]
    },
    {
      "id": 11,
      "title": "Memory Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": "Prometheus", "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Used", "refId": "A" },
        { "datasource": "Prometheus", "expr": "node_memory_MemAvailable_bytes", "legendFormat": "Available", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "id": 102,
      "title": "🔍 Traces — Distributed Tracing (Tempo)",
      "type": "row"
    },
    {
      "id": 20,
      "title": "Trace Explorer — Search & Inspect Spans",
      "type": "traces",
      "datasource": "Tempo",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 30 },
      "options": { "frameType": "TRACE_QLS" },
      "targets": [{
        "datasource": "Tempo",
        "queryType": "traceql",
        "query": "{resource.service.name=\"homelab-backend\"}",
        "refId": "A",
        "tableType": "spans",
        "limit": 20
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "id": 103,
      "title": "📋 Logs — Application Logs (Loki)",
      "type": "row"
    },
    {
      "id": 30,
      "title": "Backend Logs — All",
      "type": "logs",
      "datasource": "Loki",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 43 },
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [{
        "datasource": "Loki",
        "expr": "{container_name=~\"backend.*\"} |= ``",
        "refId": "A"
      }]
    },
    {
      "id": 31,
      "title": "Error Logs — 5xx & Exceptions",
      "type": "logs",
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 55 },
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [{
        "datasource": "Loki",
        "expr": "{container_name=~\"backend.*\"} |~ \"(?i)(error|exception|5[0-9]{2})\"",
        "refId": "A"
      }]
    }
  ]
}
