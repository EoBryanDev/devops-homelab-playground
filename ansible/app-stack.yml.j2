version: '3.8'

services:
  frontend:
    image: eobryandev/homelab-frontend:latest
    networks:
      - public-overlay
    deploy:
      replicas: 2
      placement:
        constraints:
          - node.role == worker
      labels:
        - "traefik.enable=true"
        # Route root requests to the frontend
        - "traefik.http.routers.frontend.rule=PathPrefix(`/`)"
        - "traefik.http.routers.frontend.entrypoints=websecure"
        - "traefik.http.routers.frontend.tls=true"
        - "traefik.http.services.frontend-service.loadbalancer.server.port=80"
      restart_policy:
        condition: on-failure

  backend:
    image: eobryandev/homelab-backend:latest
    networks:
      - public-overlay
    volumes:
      - sqlite-data:/data
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.role == worker
      labels:
        - "traefik.enable=true"
        # Route /api requests to the backend api
        - "traefik.http.routers.backend.rule=PathPrefix(`/api`)"
        - "traefik.http.routers.backend.entrypoints=websecure"
        - "traefik.http.routers.backend.tls=true"
        - "traefik.http.services.backend-service.loadbalancer.server.port=80"
      restart_policy:
        condition: on-failure

volumes:
  sqlite-data:

networks:
  public-overlay:
    external: true
