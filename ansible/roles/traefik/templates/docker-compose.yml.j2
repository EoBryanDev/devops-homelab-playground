services:
  traefik:
    image: traefik:latest
    command:
      # Swarm Mode Provider for Traefik v3
      - "--providers.swarm=true"
      - "--providers.swarm.exposedByDefault=false"

      # Entrypoints
      - "--entrypoints.web.address=:80"
      - "--entrypoints.websecure.address=:443"

      # Global HTTP to HTTPS redirect
      - "--entrypoints.web.http.redirections.entryPoint.to=websecure"
      - "--entrypoints.web.http.redirections.entryPoint.scheme=https"

      # API & Dashboard (insecure=true exposes dashboard on port 8080 directly)
      - "--api.dashboard=true"
      - "--api.insecure=true"

      # Enable TLS on websecure entrypoint with built-in self-signed certificate (homelab)
      - "--entrypoints.websecure.http.tls=true"

      # Enable ping endpoint for health checks
      - "--ping=true"

      # File provider for dynamic config (dashboard via HTTPS, since api@internal cannot be referenced by Swarm labels)
      - "--providers.file.directory=/etc/traefik/dynamic/"
    ports:
      - "80:80"
      - "443:443"
      - "8080:8080"
    environment:
      - DOCKER_API_VERSION=1.40
    volumes:
      - "/var/run/docker.sock:/var/run/docker.sock:ro"
    networks:
      - public-overlay
    deploy:
      placement:
        constraints:
          - node.role == manager
      labels:
        - "traefik.enable=true"
      configs:
        - source: dashboard-config
          target: /etc/traefik/dynamic/dashboard.yml
      restart_policy:
        condition: on-failure

configs:
  dashboard-config:
    file: ./dynamic.yml

networks:
  public-overlay:
    external: true
